6️⃣ Final Blade Folder Structure

Your project should finally look like this:

resources
 └── views
      ├── layouts
      │     ├── admin.blade.php
      │     └── site.blade.php
      │
      ├── admin
      │     ├── dashboard.blade.php
      │     ├── categories
      │     │     ├── index.blade.php
      │     │     ├── create.blade.php
      │     │     └── edit.blade.php
      │     │
      │     ├── posts
      │     │     ├── index.blade.php
      │     │     ├── create.blade.php
      │     │     └── edit.blade.php
      │     │
      │     └── comments
      │           └── index.blade.php
      │
      ├── site
      │     ├── index.blade.php
      │     ├── show.blade.php
      │     └── sidebar.blade.php
      │
      └── auth
            ├── login.blade.php
            └── register.blade.php

Total blade files ≈ 12–15 files.

