5 Add AJAX Script

Add this **below the form**.

```html
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

$('#addCategoryBtn').click(function(){

    var name = $('#newCategoryName').val();

    $.ajax({

        url: "{{ route('category.ajax.store') }}",

        type: "POST",

        data: {
            name: name,
            _token: "{{ csrf_token() }}"
        },

        success: function(response){

            $('#categorySelect').append(
                '<option value="'+response.id+'" selected>'
                +response.name+
                '</option>'
            );

            $('#newCategoryName').val('');

        }

    });

});

</script>
```

