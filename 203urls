 STEP 4: CONTROLLER (FINAL LOGIC )
public function category(Request $request)
{
    $categories = Category::all();

    $archives = Post::selectRaw('YEAR(created_at) year, MONTHNAME(created_at) month')
        ->orderBy('created_at','desc')
        ->distinct()
        ->get();

    $posts = Post::with('categories');

    // CATEGORY FILTER
    if($request->categories){
        foreach($request->categories as $catId){
            $posts->whereHas('categories', function($q) use ($catId){
                $q->where('categories.id', $catId);
            });
        }
    }

    //  ARCHIVE FILTER
    if($request->month && $request->year){
        $posts->whereMonth('created_at', date('m', strtotime($request->month)))
              ->whereYear('created_at', $request->year);
    }

    $posts = $posts->get();

    return view('site.index', compact('posts','categories','archives'));
}
 HOW THIS WORKS
