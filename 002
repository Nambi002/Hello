Update code:

public function up()
{
    Schema::create('users', function (Blueprint $table) {

        $table->id();

        $table->string('name');
        $table->string('email')->unique();
        $table->string('mobile');

        $table->string('password');

        $table->string('profile_image')->nullable();

        $table->enum('role',['user','admin'])->default('user');

        $table->enum('status',[
