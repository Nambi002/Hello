<?php

namespace App\Http\Controllers;

use Illuminate\Http\Request;
use App\Models\Post;
use App\Models\Category;
use App\Models\Comment;
use Carbon\Carbon;

class FrontendController extends Controller
{

    public function index()
    {

        $posts = Post::with('category','comments')
                ->latest()
                ->get();

        $categories = Category::all();

        $archives = Post::selectRaw('YEAR(created_at) year, MONTHNAME(created_at) month')
                ->orderBy('created_at','desc')
                ->distinct()
                ->get();

        return view('site.index',compact('posts','categories','archives'));
    }


    public function show($id)
    {

        $post = Post::with('comments','category')->findOrFail($id);

        $categories = Category::all();

        $archives = Post::selectRaw('YEAR(created_at) year, MONTHNAME(created_at) month')
                ->orderBy('created_at','desc')
                ->distinct()
                ->get();

        return view('site.show',compact('post','categories','archives'));
    }



    public function category($id)
    {

        $posts = Post::where('category_id',$id)->get();

        $categories = Category::all();

        $archives = Post::selectRaw('YEAR(created_at) year, MONTHNAME(created_at) month')
                ->distinct()
                ->get();

        return view('site.index',compact('posts','categories','archives'));
    }



    public function archive($month,$year)
    {

        $posts = Post::whereMonth('created_at',date('m',strtotime($month)))
                ->whereYear('created_at',$year)
                ->get();

        $categories = Category::all();

        $archives = Post::selectRaw('YEAR(created_at) year, MONTHNAME(created_at) month')
                ->distinct()
                ->get();

        return view('site.index',compact('posts','categories','archives'));
    }

}
