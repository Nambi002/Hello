public function update(Request $request)
{
    $request->validate([
        'name' => 'required',
        'mobile' => 'required'
    ]);

    $user = Auth::user();
    $user->name = $request->name;
    $user->mobile = $request->mobile;
    $user->save();

    return back()->with('success','Profile Updated');
}

