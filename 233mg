#  ADMIN CONTROLLER

```bash
php artisan make:controller AdminController
```

```php
class AdminController extends Controller
{
    public function dashboard(){
        return view('admin.dashboard');
    }

    public function unverified(){
        $users = User::where('is_verified',0)->get();
        return view('admin.users.unverified',compact('users'));
    }

    public function approve($id){
        User::find($id)->update(['is_verified'=>1]);
        return back();
    }

    public function verified(){
        $users = User::where('is_verified',1)->get();
        return view('admin.users.verified',compact('users'));
    }

    public function inactive(){
        $users = User::where('status',0)->get();
        return view('admin.users.inactive',compact('users'));
    }
}
```

